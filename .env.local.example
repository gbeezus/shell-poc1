# POC 1 — shell-poc1 configuration

# Where the third-party tool runs. Used by /tool route's iframe.
NEXT_PUBLIC_THIRDPARTY_URL=http://localhost:3001

# Where the third party's theme API lives. Used by /admin/themes when uploading
# DTCG bundles via Mechanism A.
NEXT_PUBLIC_THIRDPARTY_API=http://localhost:3001/api/theme
