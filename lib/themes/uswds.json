{
  "$description": "USWDS default federal brand (blue-60v primary). DTCG draft format (https://tr.designtokens.org/format/). Token paths flatten with '-' separator to produce CSS custom properties that match the third party's palette-layer tokens (e.g., 'brand-blue.base' -> --brand-blue-base).",
  "brand-blue": {
    "base": { "$value": "#005ea2", "$type": "color" },
    "light": { "$value": "#73b3e7", "$type": "color" },
    "light-1": { "$value": "#aacdec", "$type": "color" },
    "light-2": { "$value": "#d9e8f6", "$type": "color" },
    "dark": { "$value": "#1a4480", "$type": "color" },
    "dark-1": { "$value": "#162e51", "$type": "color" }
  },
  "brand-ocean-blue": {
    "base": { "$value": "#fa9441", "$type": "color" },
    "light": { "$value": "#ffbc78", "$type": "color" },
    "light-1": { "$value": "#ffe1c5", "$type": "color" },
    "dark": { "$value": "#c05600", "$type": "color" },
    "dark-1": { "$value": "#7b2d00", "$type": "color" }
  },
  "other-red": {
    "base": { "$value": "#b50909", "$type": "color" },
    "dark": { "$value": "#8b0a03", "$type": "color" },
    "dark-1": { "$value": "#5c0a00", "$type": "color" },
    "light": { "$value": "#f4e3db", "$type": "color" },
    "light-1": { "$value": "#f8eeee", "$type": "color" }
  },
  "other-green": {
    "base": { "$value": "#00a91c", "$type": "color" },
    "light": { "$value": "#e3f5e1", "$type": "color" }
  },
  "other-yellow": {
    "base": { "$value": "#ffbe2e", "$type": "color" },
    "light": { "$value": "#fff5c2", "$type": "color" }
  },
  "font-family-primary": {
    "$value": "var(--font-public-sans), 'Source Sans Pro', system-ui, sans-serif",
    "$type": "fontFamily"
  }
}
